---
interface Props {
	name: string;
	title: string;
	summary: string;
	primaryHref: string;
	primaryLabel: string;
	secondaryHref: string;
	secondaryLabel: string;
}

const { name, title, summary, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

<section class="hero">
	<div class="hero-copy">
		<p class="eyebrow">Portfolio</p>
		<h1>{name}</h1>
		<p class="hero-title">{title}</p>
		<p class="hero-summary">{summary}</p>

		<div class="hero-actions">
			<a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
			<a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
		</div>
	</div>
</section>

<style>
	.hero {
		padding: 2.2rem 0 0.5rem;
	}

	.hero-copy {
		display: grid;
		gap: 1rem;
		max-width: 760px;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.82rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--primary-soft);
	}

	h1 {
		margin: 0;
		font-size: clamp(2.4rem, 6vw, 5rem);
		line-height: 0.95;
	}

	.hero-title {
		margin: 0;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		font-weight: 600;
		color: var(--text-main);
	}

	.hero-summary {
		margin: 0;
		max-width: 56ch;
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--text-secondary);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		padding-top: 0.4rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.2rem;
		border-radius: 999px;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: var(--primary);
		color: var(--bg-main);
	}

	.button-secondary {
		border: 1px solid var(--border);
		background: rgba(15, 23, 42, 0.72);
		color: var(--text-main);
	}
</style>