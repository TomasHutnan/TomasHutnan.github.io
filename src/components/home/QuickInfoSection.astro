---
import Section from './Section.astro';
import type { QuickInfoItem } from '../../data/home';

interface Props {
	items: QuickInfoItem[];
}

const { items } = Astro.props;
---

<Section id="quick-info" eyebrow="Quick info" title="At a glance">
	<div class="info-grid">
		{items.map((item) => (
			<article class="info-card">
				<p>{item.label}</p>
				<strong>{item.value}</strong>
			</article>
		))}
	</div>
</Section>

<style>
	.info-grid {
		display: flex;
		gap: 1rem;
	}

	.info-card {
		padding-top: 1.2rem;
		padding-bottom: 1.2rem;
		padding-right: 2rem;
	}

	.info-card p {
		margin: 0 0 0.55rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-secondary);
	}

	.info-card strong {
		display: block;
		font-size: 1rem;
		line-height: 1.55;
		color: var(--text-main);
	}
</style>