---
import Section from './Section.astro';

interface Props {
	paragraphs: string[];
}

const { paragraphs } = Astro.props;
---

<Section id="about" eyebrow="About" title="A practical focus on AI and software">
	<div class="about-copy">
		{paragraphs.map((paragraph) => <p>{paragraph}</p>)}
	</div>
</Section>

<style>
	.about-copy {
		display: grid;
		gap: 1rem;
		max-width: 72ch;
	}

	.about-copy p {
		margin: 0;
		line-height: 1.8;
		color: var(--text-secondary);
	}
</style>