---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/home/Section.astro';
import ProjectCard from '../../components/home/ProjectCard.astro';
import { collectTagStats, type TagStat } from '../../utils/tags';
import { slugify } from '../../utils/slug';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	const tagStats = collectTagStats(projects);

	return tagStats.map((tag) => ({
		params: { slug: tag.slug },
		props: { tag }
	}));
}

interface Props {
	tag: TagStat;
}

const { tag } = Astro.props;
const projects = await getCollection('projects');
const matchingProjects = projects
	.filter((project) => project.data.tags.some((projectTag) => slugify(projectTag) === tag.slug))
	.sort((left, right) => {
		const leftDate = left.data.completedAt ?? left.data.startedAt ?? new Date(0);
		const rightDate = right.data.completedAt ?? right.data.startedAt ?? new Date(0);
		return rightDate.getTime() - leftDate.getTime();
	});
---

<Layout
	pageTitle={tag.tag}
	description={`Projects tagged with ${tag.tag} in Tomáš Hutňan's portfolio.`}
>
	<main class="tag-page">
		<Section
			eyebrow="Tags"
            eyebrowHref="/tags"
			title={tag.tag}
			description={`Showing ${matchingProjects.length} project${matchingProjects.length === 1 ? '' : 's'} for this tag.`}
		>
			<div class="projects-grid">
				{matchingProjects.map((project) => <ProjectCard project={project} />)}
			</div>
		</Section>
	</main>
</Layout>

<style>
	.tag-page {
		max-width: 1160px;
		margin: 0 auto;
		padding: 2rem 1rem 4rem;
	}

	.page-links {
		display: flex;
		justify-content: flex-end;
	}

	.page-links a {
		color: var(--primary-soft);
		text-decoration: none;
		font-weight: 600;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1rem;
	}
</style>
