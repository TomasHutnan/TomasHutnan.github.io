---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import QuickInfoSection from '../components/home/QuickInfoSection.astro';
import AboutSection from '../components/home/AboutSection.astro';
import SkillsSection from '../components/home/SkillsSection.astro';
import FeaturedProjectsSection from '../components/home/FeaturedProjectsSection.astro';
import AwardsTimelineSection from '../components/home/AwardsTimelineSection.astro';
import ExperienceSection from '../components/home/ExperienceSection.astro';
import ContactSection from '../components/home/ContactSection.astro';
import {
	hero,
	quickInfo,
	aboutParagraphs,
	skillGroups,
	experienceEntries,
	contactLinks,
} from '../data/home';

const projects = await getCollection('projects');
const awards = await getCollection('awards');
const featuredProjects = projects
	.filter((project) => project.data.featured)
	.sort((a, b) => (a.data.featuredOrder ?? 0) - (b.data.featuredOrder ?? 0));

---

<Layout
	pageTitle="Home"
	description="Portfolio of Tomáš Hutňan, an informatics student focused on machine learning, computer vision, and full-stack software."
>
	<main class="home-page">
		<HeroSection
			name={hero.name}
			title={hero.title}
			summary={hero.summary}
			primaryHref="/projects"
			primaryLabel="View Projects"
			secondaryHref="#contact"
			secondaryLabel="Contact Me"
		/>

		<div class="home-sections">
			<QuickInfoSection items={quickInfo} />
			<AboutSection paragraphs={aboutParagraphs} />
			<SkillsSection groups={skillGroups} />
			<FeaturedProjectsSection projects={featuredProjects} />
			<AwardsTimelineSection awards={awards} />
			<ExperienceSection entries={experienceEntries} />
			<ContactSection links={contactLinks} />
		</div>
	</main>
</Layout>

<style>
	.home-page {
		max-width: 1160px;
		margin: 0 auto;
		padding: 2rem 1rem 4rem;
		display: grid;
		gap: 2.2rem;
	}

	.home-sections {
		display: grid;
		gap: 2.2rem;
	}
</style>
